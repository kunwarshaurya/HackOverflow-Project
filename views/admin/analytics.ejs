<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <link rel="stylesheet" href="/css/main.css">
    <link rel="stylesheet" href="/css/partials.css">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
</head>

<body>
    <% if (locals.showNavbar !==false) { %>
        <%- include('../partials/navbar') %>
            <% } %>

                <main class="main-content">
                    <div class="page-header">
                        <div class="container">
                            <div
                                style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px">
                                <div>
                                    <h1 class="page-title"><i class="fas fa-chart-bar"></i> Analytics Dashboard</h1>
                                    <p class="page-subtitle">Participation trends, club activity, resource utilization &
                                        budget insights</p>
                                </div>
                                <div class="export-buttons">
                                    <a href="/admin/analytics/export?type=participation"
                                        class="btn btn-outline btn-sm"><i class="fas fa-download"></i> Participation
                                        CSV</a>
                                    <a href="/admin/analytics/export?type=club" class="btn btn-outline btn-sm"><i
                                            class="fas fa-download"></i> Club CSV</a>
                                    <a href="/admin/analytics/export?type=resource" class="btn btn-outline btn-sm"><i
                                            class="fas fa-download"></i> Resource CSV</a>
                                    <a href="/admin/analytics/export?type=budget" class="btn btn-outline btn-sm"><i
                                            class="fas fa-download"></i> Budget CSV</a>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="container">
                        <!-- Budget Summary Cards -->
                        <div class="stats-grid">
                            <div class="stat-card stat-primary">
                                <div class="stat-icon"><i class="fas fa-wallet"></i></div>
                                <div class="stat-body">
                                    <div class="stat-value">₹<%= budget.total ? budget.total.toLocaleString() : '0' %>
                                    </div>
                                    <div class="stat-label">Total Approved Budget</div>
                                </div>
                            </div>
                            <div class="stat-card stat-success">
                                <div class="stat-icon"><i class="fas fa-calendar-check"></i></div>
                                <div class="stat-body">
                                    <div class="stat-value">
                                        <%= budget.approvedCount %>
                                    </div>
                                    <div class="stat-label">Approved Events</div>
                                </div>
                            </div>
                            <div class="stat-card stat-info">
                                <div class="stat-icon"><i class="fas fa-users-cog"></i></div>
                                <div class="stat-body">
                                    <div class="stat-value">
                                        <%= clubActivity.length %>
                                    </div>
                                    <div class="stat-label">Active Clubs</div>
                                </div>
                            </div>
                            <div class="stat-card stat-warning">
                                <div class="stat-icon"><i class="fas fa-map-marker-alt"></i></div>
                                <div class="stat-body">
                                    <div class="stat-value">
                                        <%= venueUtil.length %>
                                    </div>
                                    <div class="stat-label">Venues in Use</div>
                                </div>
                            </div>
                        </div>

                        <!-- Charts Row 1 -->
                        <div class="charts-row">
                            <div class="chart-card">
                                <h3 class="chart-title"><i class="fas fa-chart-line"></i> Participation Trends</h3>
                                <div class="chart-wrapper">
                                    <canvas id="participationChart"></canvas>
                                </div>
                                <% if (participation.length===0) { %>
                                    <div class="chart-empty"><i class="fas fa-info-circle"></i> No registration data yet
                                    </div>
                                    <% } %>
                            </div>
                            <div class="chart-card">
                                <h3 class="chart-title"><i class="fas fa-chart-bar"></i> Club Activity</h3>
                                <div class="chart-wrapper">
                                    <canvas id="clubChart"></canvas>
                                </div>
                                <% if (clubActivity.length===0) { %>
                                    <div class="chart-empty"><i class="fas fa-info-circle"></i> No club data yet</div>
                                    <% } %>
                            </div>
                        </div>

                        <!-- Charts Row 2 -->
                        <div class="charts-row">
                            <div class="chart-card">
                                <h3 class="chart-title"><i class="fas fa-building"></i> Resource Utilization</h3>
                                <div class="chart-wrapper">
                                    <canvas id="resourceChart"></canvas>
                                </div>
                                <% if (venueUtil.length===0 && equipmentUtil.length===0) { %>
                                    <div class="chart-empty"><i class="fas fa-info-circle"></i> No resource data yet
                                    </div>
                                    <% } %>
                            </div>
                            <div class="chart-card">
                                <h3 class="chart-title"><i class="fas fa-coins"></i> Budget by Club</h3>
                                <div class="chart-wrapper">
                                    <canvas id="budgetChart"></canvas>
                                </div>
                                <% if (budget.byClub.length===0) { %>
                                    <div class="chart-empty"><i class="fas fa-info-circle"></i> No budget data yet</div>
                                    <% } %>
                            </div>
                        </div>

                        <!-- Monthly Budget Table -->
                        <% if (budget.monthly.length> 0) { %>
                            <div class="chart-card" style="margin-bottom:24px">
                                <h3 class="chart-title"><i class="fas fa-table"></i> Monthly Budget Allocation</h3>
                                <div class="table-wrapper">
                                    <table class="data-table">
                                        <thead>
                                            <tr>
                                                <th>Month</th>
                                                <th>Events</th>
                                                <th>Budget</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% const
                                                months=['','Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
                                                %>
                                                <% budget.monthly.forEach(m=> { %>
                                                    <tr>
                                                        <td>
                                                            <%= months[m.month] %>
                                                                <%= m.year %>
                                                        </td>
                                                        <td>
                                                            <%= m.eventCount %>
                                                        </td>
                                                        <td>₹<%= m.totalBudget.toLocaleString() %>
                                                        </td>
                                                    </tr>
                                                    <% }) %>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                            <% } %>

                                <!-- Club Activity Table -->
                                <% if (clubActivity.length> 0) { %>
                                    <div class="chart-card" style="margin-bottom:24px">
                                        <h3 class="chart-title"><i class="fas fa-list-alt"></i> Club Activity Details
                                        </h3>
                                        <div class="table-wrapper">
                                            <table class="data-table">
                                                <thead>
                                                    <tr>
                                                        <th>Club</th>
                                                        <th>Events</th>
                                                        <th>Registrations</th>
                                                        <th>Approved</th>
                                                        <th>Pending</th>
                                                        <th>Rejected</th>
                                                        <th>Completed</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <% clubActivity.forEach(c=> { %>
                                                        <tr>
                                                            <td><strong>
                                                                    <%= c.clubName %>
                                                                </strong></td>
                                                            <td>
                                                                <%= c.totalEvents %>
                                                            </td>
                                                            <td>
                                                                <%= c.totalRegistrations %>
                                                            </td>
                                                            <td><span class="badge-green">
                                                                    <%= c.approved %>
                                                                </span></td>
                                                            <td><span class="badge-yellow">
                                                                    <%= c.pending %>
                                                                </span></td>
                                                            <td><span class="badge-red">
                                                                    <%= c.rejected %>
                                                                </span></td>
                                                            <td><span class="badge-blue">
                                                                    <%= c.completed %>
                                                                </span></td>
                                                        </tr>
                                                        <% }) %>
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                    <% } %>
                    </div>

                    <script>
                        const MONTHS = ['', 'Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
                        const COLORS = ['#667eea', '#48bb78', '#ed8936', '#e53e3e', '#9f7aea', '#38b2ac', '#f56565', '#4299e1', '#ecc94b', '#fc8181'];

                        // ===== 1. Participation Trends Line Chart =====
                        const pData = <% - JSON.stringify(participation) %>;
                        if (pData.length > 0) {
                            new Chart(document.getElementById('participationChart'), {
                                type: 'line',
                                data: {
                                    labels: pData.map(d => MONTHS[d.month] + ' ' + d.year),
                                    datasets: [{
                                        label: 'Registrations',
                                        data: pData.map(d => d.totalRegistrations),
                                        borderColor: '#667eea',
                                        backgroundColor: 'rgba(102,126,234,0.1)',
                                        fill: true,
                                        tension: 0.4,
                                        pointRadius: 5,
                                        pointHoverRadius: 7
                                    }, {
                                        label: 'Events',
                                        data: pData.map(d => d.eventCount),
                                        borderColor: '#48bb78',
                                        backgroundColor: 'rgba(72,187,120,0.1)',
                                        fill: true,
                                        tension: 0.4,
                                        pointRadius: 5,
                                        pointHoverRadius: 7
                                    }]
                                },
                                options: {
                                    responsive: true,
                                    maintainAspectRatio: false,
                                    plugins: { legend: { position: 'bottom' } },
                                    scales: { y: { beginAtZero: true, ticks: { precision: 0 } } }
                                }
                            });
                        }

                        // ===== 2. Club Activity Bar Chart =====
                        const cData = <% - JSON.stringify(clubActivity) %>;
                        if (cData.length > 0) {
                            new Chart(document.getElementById('clubChart'), {
                                type: 'bar',
                                data: {
                                    labels: cData.map(c => c.clubName.length > 15 ? c.clubName.substring(0, 15) + '…' : c.clubName),
                                    datasets: [{
                                        label: 'Events',
                                        data: cData.map(c => c.totalEvents),
                                        backgroundColor: '#667eea'
                                    }, {
                                        label: 'Registrations',
                                        data: cData.map(c => c.totalRegistrations),
                                        backgroundColor: '#48bb78'
                                    }]
                                },
                                options: {
                                    responsive: true,
                                    maintainAspectRatio: false,
                                    plugins: { legend: { position: 'bottom' } },
                                    scales: { y: { beginAtZero: true, ticks: { precision: 0 } } }
                                }
                            });
                        }

                        // ===== 3. Resource Utilization Bar Chart =====
                        const vData = <% - JSON.stringify(venueUtil) %>;
                        const eData = <% - JSON.stringify(equipmentUtil) %>;
                        const rLabels = [...vData.map(v => v.venueName), ...eData.map(e => e.equipmentName)];
                        const rValues = [...vData.map(v => v.eventCount), ...eData.map(e => e.bookingCount)];
                        const rColors = rLabels.map((_, i) => i < vData.length ? '#4299e1' : '#ed8936');
                        if (rLabels.length > 0) {
                            new Chart(document.getElementById('resourceChart'), {
                                type: 'bar',
                                data: {
                                    labels: rLabels.map(l => l.length > 15 ? l.substring(0, 15) + '…' : l),
                                    datasets: [{
                                        label: 'Usage Count',
                                        data: rValues,
                                        backgroundColor: rColors
                                    }]
                                },
                                options: {
                                    responsive: true,
                                    maintainAspectRatio: false,
                                    plugins: { legend: { display: false } },
                                    scales: { y: { beginAtZero: true, ticks: { precision: 0 } } }
                                }
                            });
                        }

                        // ===== 4. Budget by Club Doughnut =====
                        const bData = <% - JSON.stringify(budget.byClub) %>;
                        if (bData.length > 0) {
                            new Chart(document.getElementById('budgetChart'), {
                                type: 'doughnut',
                                data: {
                                    labels: bData.map(b => b.clubName),
                                    datasets: [{
                                        data: bData.map(b => b.totalBudget),
                                        backgroundColor: COLORS.slice(0, bData.length),
                                        borderWidth: 2
                                    }]
                                },
                                options: {
                                    responsive: true,
                                    maintainAspectRatio: false,
                                    plugins: {
                                        legend: { position: 'bottom' },
                                        tooltip: {
                                            callbacks: {
                                                label: function (ctx) {
                                                    return ctx.label + ': ₹' + ctx.raw.toLocaleString();
                                                }
                                            }
                                        }
                                    }
                                }
                            });
                        }
                    </script>

                    <style>
                        .stats-grid {
                            display: grid;
                            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
                            gap: 16px;
                            margin-bottom: 24px;
                        }

                        .stat-card {
                            display: flex;
                            align-items: center;
                            gap: 16px;
                            padding: 20px;
                            border-radius: 12px;
                            background: white;
                            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
                        }

                        .stat-icon {
                            width: 50px;
                            height: 50px;
                            display: flex;
                            align-items: center;
                            justify-content: center;
                            border-radius: 12px;
                            font-size: 20px;
                        }

                        .stat-primary .stat-icon {
                            background: #ebf4ff;
                            color: #667eea;
                        }

                        .stat-success .stat-icon {
                            background: #c6f6d5;
                            color: #38a169;
                        }

                        .stat-info .stat-icon {
                            background: #bee3f8;
                            color: #3182ce;
                        }

                        .stat-warning .stat-icon {
                            background: #fefcbf;
                            color: #d69e2e;
                        }

                        .stat-value {
                            font-size: 24px;
                            font-weight: 700;
                            color: #2d3748;
                        }

                        .stat-label {
                            font-size: 13px;
                            color: #718096;
                            margin-top: 2px;
                        }

                        .charts-row {
                            display: grid;
                            grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
                            gap: 20px;
                            margin-bottom: 24px;
                        }

                        .chart-card {
                            background: white;
                            border-radius: 12px;
                            padding: 24px;
                            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
                        }

                        .chart-title {
                            font-size: 16px;
                            color: #2d3748;
                            margin-bottom: 16px;
                            display: flex;
                            align-items: center;
                            gap: 8px;
                        }

                        .chart-wrapper {
                            position: relative;
                            height: 280px;
                        }

                        .chart-empty {
                            text-align: center;
                            padding: 20px;
                            color: #a0aec0;
                            font-size: 14px;
                        }

                        .export-buttons {
                            display: flex;
                            flex-wrap: wrap;
                            gap: 8px;
                        }

                        .btn-outline {
                            background: transparent;
                            border: 1px solid #cbd5e0;
                            color: #4a5568;
                            padding: 6px 14px;
                            border-radius: 6px;
                            font-size: 13px;
                            font-weight: 500;
                            text-decoration: none;
                            display: inline-flex;
                            align-items: center;
                            gap: 6px;
                            transition: all 0.2s;
                        }

                        .btn-outline:hover {
                            background: #667eea;
                            color: white;
                            border-color: #667eea;
                        }

                        .btn-sm {
                            padding: 6px 14px;
                            font-size: 13px;
                        }

                        .table-wrapper {
                            overflow-x: auto;
                        }

                        .data-table {
                            width: 100%;
                            border-collapse: collapse;
                        }

                        .data-table th,
                        .data-table td {
                            padding: 10px 14px;
                            text-align: left;
                            border-bottom: 1px solid #e2e8f0;
                        }

                        .data-table th {
                            background: #f7fafc;
                            font-weight: 600;
                            color: #4a5568;
                            font-size: 12px;
                            text-transform: uppercase;
                            letter-spacing: 0.05em;
                        }

                        .data-table tr:hover {
                            background: #f7fafc;
                        }

                        .badge-green {
                            display: inline-block;
                            padding: 2px 8px;
                            border-radius: 10px;
                            background: #c6f6d5;
                            color: #276749;
                            font-size: 12px;
                            font-weight: 600;
                        }

                        .badge-yellow {
                            display: inline-block;
                            padding: 2px 8px;
                            border-radius: 10px;
                            background: #fefcbf;
                            color: #975a16;
                            font-size: 12px;
                            font-weight: 600;
                        }

                        .badge-red {
                            display: inline-block;
                            padding: 2px 8px;
                            border-radius: 10px;
                            background: #fed7d7;
                            color: #c53030;
                            font-size: 12px;
                            font-weight: 600;
                        }

                        .badge-blue {
                            display: inline-block;
                            padding: 2px 8px;
                            border-radius: 10px;
                            background: #bee3f8;
                            color: #2b6cb0;
                            font-size: 12px;
                            font-weight: 600;
                        }

                        @media (max-width: 768px) {
                            .charts-row {
                                grid-template-columns: 1fr;
                            }

                            .stats-grid {
                                grid-template-columns: repeat(2, 1fr);
                            }

                            .export-buttons {
                                justify-content: center;
                            }
                        }
                    </style>
                </main>

                <% if (locals.showNavbar !==false) { %>
                    <%- include('../partials/footer') %>
                        <% } %>

                            <script src="/js/main.js"></script>
                            <script src="/js/partials.js"></script>
</body>

</html>