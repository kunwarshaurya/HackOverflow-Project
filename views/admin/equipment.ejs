<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <link rel="stylesheet" href="/css/main.css">
    <link rel="stylesheet" href="/css/partials.css">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
</head>

<body>
    <% if (locals.showNavbar !==false) { %>
        <%- include('../partials/navbar') %>
            <% } %>

                <main class="main-content">
                    <div class="page-header">
                        <div class="container">
                            <h1 class="page-title">
                                <i class="fas fa-toolbox"></i>
                                Equipment Management
                            </h1>
                            <p class="page-subtitle">Manage campus equipment and approve booking requests</p>
                        </div>
                    </div>

                    <div class="container">
                        <% if (locals.error) { %>
                            <div class="alert alert-error">
                                <i class="fas fa-exclamation-circle"></i>
                                <%= error %>
                            </div>
                            <% } %>
                                <% if (locals.success) { %>
                                    <div class="alert alert-success">
                                        <i class="fas fa-check-circle"></i>
                                        <%= success %>
                                    </div>
                                    <% } %>

                                        <!-- Add Equipment Form -->
                                        <div class="section-card">
                                            <h3 class="section-title"><i class="fas fa-plus-circle"></i> Add New
                                                Equipment</h3>
                                            <form action="/admin/equipment" method="POST" class="inline-form">
                                                <div class="form-row">
                                                    <div class="form-group">
                                                        <label for="name" class="form-label">Name *</label>
                                                        <input type="text" id="name" name="name" class="form-input"
                                                            required placeholder="e.g. Projector">
                                                    </div>
                                                    <div class="form-group">
                                                        <label for="category" class="form-label">Category *</label>
                                                        <input type="text" id="category" name="category"
                                                            class="form-input" required placeholder="e.g. AV Equipment">
                                                    </div>
                                                    <div class="form-group">
                                                        <label for="totalQuantity" class="form-label">Quantity *</label>
                                                        <input type="number" id="totalQuantity" name="totalQuantity"
                                                            class="form-input" required min="1" value="1">
                                                    </div>
                                                </div>
                                                <div class="form-group">
                                                    <label for="description" class="form-label">Description</label>
                                                    <input type="text" id="description" name="description"
                                                        class="form-input" placeholder="Optional description">
                                                </div>
                                                <button type="submit" class="btn btn-primary">
                                                    <i class="fas fa-plus"></i> Add Equipment
                                                </button>
                                            </form>
                                        </div>

                                        <!-- Equipment Inventory -->
                                        <div class="section-card">
                                            <h3 class="section-title"><i class="fas fa-boxes"></i> Equipment Inventory (
                                                <%= equipment.length %>)</h3>
                                            <% if (equipment.length> 0) { %>
                                                <div class="table-wrapper">
                                                    <table class="data-table">
                                                        <thead>
                                                            <tr>
                                                                <th>Name</th>
                                                                <th>Category</th>
                                                                <th>Quantity</th>
                                                                <th>Description</th>
                                                                <th>Actions</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            <% equipment.forEach(item=> { %>
                                                                <tr>
                                                                    <td><strong>
                                                                            <%= item.name %>
                                                                        </strong></td>
                                                                    <td><span class="category-badge">
                                                                            <%= item.category %>
                                                                        </span></td>
                                                                    <td>
                                                                        <%= item.totalQuantity %>
                                                                    </td>
                                                                    <td>
                                                                        <%= item.description || '—' %>
                                                                    </td>
                                                                    <td>
                                                                        <form
                                                                            action="/admin/equipment/<%= item._id %>/delete"
                                                                            method="POST" style="display:inline"
                                                                            onsubmit="return confirm('Delete this equipment?')">
                                                                            <button type="submit"
                                                                                class="btn btn-sm btn-danger">
                                                                                <i class="fas fa-trash"></i>
                                                                            </button>
                                                                        </form>
                                                                    </td>
                                                                </tr>
                                                                <% }) %>
                                                        </tbody>
                                                    </table>
                                                </div>
                                                <% } else { %>
                                                    <div class="empty-state-sm">
                                                        <i class="fas fa-box-open"></i>
                                                        <p>No equipment added yet.</p>
                                                    </div>
                                                    <% } %>
                                        </div>

                                        <!-- Pending Bookings -->
                                        <div class="section-card">
                                            <h3 class="section-title"><i class="fas fa-clipboard-list"></i> Pending
                                                Booking Requests (<%= pendingBookings.length %>)</h3>
                                            <% if (pendingBookings.length> 0) { %>
                                                <div class="bookings-list">
                                                    <% pendingBookings.forEach(booking=> { %>
                                                        <div class="booking-card">
                                                            <div class="booking-info">
                                                                <div class="booking-header">
                                                                    <strong>
                                                                        <%= booking.equipment ? booking.equipment.name
                                                                            : 'Unknown' %>
                                                                    </strong>
                                                                    <span class="status-badge pending">Pending</span>
                                                                </div>
                                                                <div class="booking-meta">
                                                                    <span><i class="fas fa-calendar"></i>
                                                                        <%= booking.date ? new
                                                                            Date(booking.date).toLocaleDateString()
                                                                            : 'N/A' %>
                                                                    </span>
                                                                    <span><i class="fas fa-clock"></i>
                                                                        <%= Math.floor(booking.startTime /
                                                                            60).toString().padStart(2,'0') %>:<%=
                                                                                (booking.startTime %
                                                                                60).toString().padStart(2,'0') %> —
                                                                                <%= Math.floor(booking.endTime /
                                                                                    60).toString().padStart(2,'0') %>:
                                                                                    <%= (booking.endTime %
                                                                                        60).toString().padStart(2,'0')
                                                                                        %>
                                                                    </span>
                                                                    <span><i class="fas fa-cubes"></i> Qty: <%=
                                                                            booking.quantity %></span>
                                                                    <span><i class="fas fa-calendar-alt"></i> Event: <%=
                                                                            booking.event ? booking.event.name : 'N/A'
                                                                            %></span>
                                                                    <span><i class="fas fa-user"></i> By: <%=
                                                                            booking.bookedBy ? booking.bookedBy.name
                                                                            : 'N/A' %></span>
                                                                </div>
                                                            </div>
                                                            <div class="booking-actions">
                                                                <form
                                                                    action="/admin/equipment/bookings/<%= booking._id %>/status"
                                                                    method="POST" style="display:inline">
                                                                    <button type="submit" name="status" value="approved"
                                                                        class="btn btn-sm btn-success">
                                                                        <i class="fas fa-check"></i> Approve
                                                                    </button>
                                                                    <button type="submit" name="status" value="rejected"
                                                                        class="btn btn-sm btn-danger">
                                                                        <i class="fas fa-times"></i> Reject
                                                                    </button>
                                                                </form>
                                                            </div>
                                                        </div>
                                                        <% }) %>
                                                </div>
                                                <% } else { %>
                                                    <div class="empty-state-sm">
                                                        <i class="fas fa-clipboard-check"></i>
                                                        <p>No pending equipment booking requests.</p>
                                                    </div>
                                                    <% } %>
                                        </div>
                    </div>

                    <style>
                        .section-card {
                            background: white;
                            border-radius: 12px;
                            padding: 24px;
                            margin-bottom: 24px;
                            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
                        }

                        .section-title {
                            color: #2d3748;
                            margin-bottom: 20px;
                            padding-bottom: 12px;
                            border-bottom: 2px solid #e2e8f0;
                            display: flex;
                            align-items: center;
                            gap: 10px;
                        }

                        .inline-form .form-row {
                            display: grid;
                            grid-template-columns: 2fr 1fr 1fr;
                            gap: 16px;
                            margin-bottom: 16px;
                        }

                        .form-group {
                            margin-bottom: 16px;
                        }

                        .form-label {
                            display: block;
                            margin-bottom: 6px;
                            color: #4a5568;
                            font-weight: 600;
                            font-size: 14px;
                        }

                        .form-input {
                            width: 100%;
                            padding: 10px 14px;
                            border: 2px solid #e2e8f0;
                            border-radius: 8px;
                            font-size: 15px;
                            transition: border-color 0.2s;
                        }

                        .form-input:focus {
                            outline: none;
                            border-color: #667eea;
                        }

                        .table-wrapper {
                            overflow-x: auto;
                        }

                        .data-table {
                            width: 100%;
                            border-collapse: collapse;
                        }

                        .data-table th,
                        .data-table td {
                            padding: 12px 16px;
                            text-align: left;
                            border-bottom: 1px solid #e2e8f0;
                        }

                        .data-table th {
                            background: #f7fafc;
                            font-weight: 600;
                            color: #4a5568;
                            font-size: 13px;
                            text-transform: uppercase;
                            letter-spacing: 0.05em;
                        }

                        .data-table tr:hover {
                            background: #f7fafc;
                        }

                        .category-badge {
                            display: inline-block;
                            padding: 4px 10px;
                            border-radius: 20px;
                            background: #ebf4ff;
                            color: #3182ce;
                            font-size: 13px;
                            font-weight: 500;
                        }

                        .booking-card {
                            display: flex;
                            justify-content: space-between;
                            align-items: center;
                            gap: 16px;
                            padding: 16px;
                            border: 1px solid #e2e8f0;
                            border-radius: 10px;
                            margin-bottom: 12px;
                            transition: box-shadow 0.2s;
                        }

                        .booking-card:hover {
                            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
                        }

                        .booking-header {
                            display: flex;
                            align-items: center;
                            gap: 12px;
                            margin-bottom: 8px;
                        }

                        .booking-meta {
                            display: flex;
                            flex-wrap: wrap;
                            gap: 16px;
                            font-size: 14px;
                            color: #718096;
                        }

                        .booking-meta i {
                            margin-right: 4px;
                        }

                        .booking-actions {
                            display: flex;
                            gap: 8px;
                            flex-shrink: 0;
                        }

                        .status-badge.pending {
                            padding: 4px 10px;
                            border-radius: 20px;
                            background: #fefcbf;
                            color: #d69e2e;
                            font-size: 12px;
                            font-weight: 600;
                        }

                        .empty-state-sm {
                            text-align: center;
                            padding: 24px;
                            color: #a0aec0;
                        }

                        .empty-state-sm i {
                            font-size: 2rem;
                            margin-bottom: 8px;
                            display: block;
                        }

                        .alert {
                            padding: 14px 18px;
                            border-radius: 8px;
                            margin-bottom: 20px;
                            display: flex;
                            align-items: center;
                            gap: 10px;
                        }

                        .alert-error {
                            background: #fed7d7;
                            color: #c53030;
                            border-left: 4px solid #e53e3e;
                        }

                        .alert-success {
                            background: #c6f6d5;
                            color: #276749;
                            border-left: 4px solid #38a169;
                        }

                        .btn {
                            padding: 10px 18px;
                            border: none;
                            border-radius: 8px;
                            font-weight: 600;
                            cursor: pointer;
                            display: inline-flex;
                            align-items: center;
                            gap: 6px;
                            transition: all 0.2s;
                            text-decoration: none;
                            font-size: 14px;
                        }

                        .btn-primary {
                            background: #667eea;
                            color: white;
                        }

                        .btn-primary:hover {
                            background: #5a67d8;
                        }

                        .btn-success {
                            background: #48bb78;
                            color: white;
                        }

                        .btn-success:hover {
                            background: #38a169;
                        }

                        .btn-danger {
                            background: #fc8181;
                            color: white;
                        }

                        .btn-danger:hover {
                            background: #e53e3e;
                        }

                        .btn-sm {
                            padding: 6px 12px;
                            font-size: 13px;
                        }

                        @media (max-width: 768px) {
                            .inline-form .form-row {
                                grid-template-columns: 1fr;
                            }

                            .booking-card {
                                flex-direction: column;
                                align-items: flex-start;
                            }

                            .booking-actions {
                                align-self: flex-end;
                            }
                        }
                    </style>
                </main>

                <% if (locals.showNavbar !==false) { %>
                    <%- include('../partials/footer') %>
                        <% } %>

                            <script src="/js/main.js"></script>
                            <script src="/js/partials.js"></script>
</body>

</html>