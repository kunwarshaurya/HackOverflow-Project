<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <link rel="stylesheet" href="/css/main.css">
    <link rel="stylesheet" href="/css/partials.css">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
</head>

<body>
    <% if (locals.showNavbar !==false) { %>
        <%- include('../partials/navbar') %>
            <% } %>

                <main class="main-content">
                    <div class="page-header">
                        <div class="container">
                            <div class="header-content">
                                <div class="header-text">
                                    <h1 class="page-title">
                                        <i class="fas fa-tachometer-alt"></i>
                                        Club Dashboard
                                    </h1>
                                    <p class="page-subtitle">Welcome back, <%= user.name %>! Manage your club events and
                                            activities.</p>
                                </div>

                                <div class="header-actions">
                                    <a href="/club/create-event" class="btn btn-primary">
                                        <i class="fas fa-plus"></i>
                                        Create Event
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="container">
                        <% if (error) { %>
                            <div class="alert alert-error">
                                <i class="fas fa-exclamation-circle"></i>
                                <%= error %>
                            </div>
                            <% } %>

                                <% if (success) { %>
                                    <div class="alert alert-success">
                                        <i class="fas fa-check-circle"></i>
                                        <%= success %>
                                    </div>
                                    <% } %>

                                        <!-- Dashboard Stats -->
                                        <div class="stats-grid">
                                            <div class="stat-card">
                                                <div class="stat-icon">
                                                    <i class="fas fa-calendar-alt"></i>
                                                </div>
                                                <div class="stat-content">
                                                    <div class="stat-number">
                                                        <%= totalEvents || 0 %>
                                                    </div>
                                                    <div class="stat-label">Total Events</div>
                                                </div>
                                            </div>

                                            <div class="stat-card">
                                                <div class="stat-icon">
                                                    <i class="fas fa-check-circle"></i>
                                                </div>
                                                <div class="stat-content">
                                                    <div class="stat-number">
                                                        <%= activeEvents || 0 %>
                                                    </div>
                                                    <div class="stat-label">Active Events</div>
                                                </div>
                                            </div>

                                            <div class="stat-card">
                                                <div class="stat-icon">
                                                    <i class="fas fa-clock"></i>
                                                </div>
                                                <div class="stat-content">
                                                    <div class="stat-number">
                                                        <%= pendingEvents || 0 %>
                                                    </div>
                                                    <div class="stat-label">Pending Approval</div>
                                                </div>
                                            </div>

                                            <div class="stat-card">
                                                <div class="stat-icon">
                                                    <i class="fas fa-users"></i>
                                                </div>
                                                <div class="stat-content">
                                                    <div class="stat-number">
                                                        <%= totalRegistrations || 0 %>
                                                    </div>
                                                    <div class="stat-label">Total Registrations</div>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Automation Intelligence -->
                                        <% const completedCount=(recentEvents || []).filter(e=> e.status ===
                                            'completed').length;
                                            const reminderCount = (recentEvents || []).filter(e => e.reminderSent ===
                                            true).length;
                                            %>
                                            <div class="stats-grid" style="margin-top:-0.5rem">
                                                <div class="stat-card" style="border-left:4px solid #667eea">
                                                    <div class="stat-icon"
                                                        style="background:linear-gradient(135deg,#4299e1,#667eea)">
                                                        <i class="fas fa-robot"></i>
                                                    </div>
                                                    <div class="stat-content">
                                                        <div class="stat-number">
                                                            <%= completedCount %>
                                                        </div>
                                                        <div class="stat-label">Auto-Completed</div>
                                                    </div>
                                                </div>
                                                <div class="stat-card" style="border-left:4px solid #38a169">
                                                    <div class="stat-icon"
                                                        style="background:linear-gradient(135deg,#38a169,#48bb78)">
                                                        <i class="fas fa-bell"></i>
                                                    </div>
                                                    <div class="stat-content">
                                                        <div class="stat-number">
                                                            <%= reminderCount %>
                                                        </div>
                                                        <div class="stat-label">Reminders Sent</div>
                                                    </div>
                                                </div>
                                            </div>

                                            <!-- Club Performance Summary -->
                                            <% const ca=typeof clubAnalytics !=='undefined' ? clubAnalytics : {}; %>
                                                <div class="card" style="margin-bottom:1.5rem;margin-top:1rem">
                                                    <div class="card-header">
                                                        <h2><i class="fas fa-chart-line"></i> Performance Summary</h2>
                                                    </div>
                                                    <div class="card-body">
                                                        <div class="stats-grid"
                                                            style="grid-template-columns:repeat(3,1fr)">
                                                            <div class="stat-card"
                                                                style="text-align:center;border-left:4px solid #667eea">
                                                                <div
                                                                    style="width:64px;height:64px;border-radius:50%;margin:0 auto 0.5rem;background:conic-gradient(#667eea <%= (ca.approvalRate || 0) * 3.6 %>deg, #e2e8f0 0deg);display:flex;align-items:center;justify-content:center">
                                                                    <span
                                                                        style="background:#fff;width:48px;height:48px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:0.85rem;color:#667eea">
                                                                        <%= ca.approvalRate || 0 %>%
                                                                    </span>
                                                                </div>
                                                                <div class="stat-label">Approval Rate</div>
                                                            </div>
                                                            <div class="stat-card"
                                                                style="text-align:center;border-left:4px solid #38a169">
                                                                <div
                                                                    style="width:64px;height:64px;border-radius:50%;margin:0 auto 0.5rem;background:conic-gradient(#38a169 <%= (ca.completionRate || 0) * 3.6 %>deg, #e2e8f0 0deg);display:flex;align-items:center;justify-content:center">
                                                                    <span
                                                                        style="background:#fff;width:48px;height:48px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:0.85rem;color:#38a169">
                                                                        <%= ca.completionRate || 0 %>%
                                                                    </span>
                                                                </div>
                                                                <div class="stat-label">Completion Rate</div>
                                                            </div>
                                                            <div class="stat-card"
                                                                style="text-align:center;border-left:4px solid #ed8936">
                                                                <div
                                                                    style="font-size:1.75rem;font-weight:700;color:#ed8936;margin-bottom:0.25rem">
                                                                    <%= ca.avgRegistrations || 0 %>
                                                                </div>
                                                                <div class="stat-label">Avg. Registrations</div>
                                                                <div
                                                                    style="font-size:0.7rem;color:#a0aec0;margin-top:0.25rem">
                                                                    per event</div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>

                                                <!-- Analytics Charts -->
                                                <div class="dashboard-section">
                                                    <h2 class="section-title"><i class="fas fa-chart-bar"></i> Analytics
                                                    </h2>
                                                    <div class="charts-grid">
                                                        <div class="chart-card">
                                                            <h4 class="chart-title">Event Status Distribution</h4>
                                                            <div class="chart-container-sm"><canvas
                                                                    id="statusChart"></canvas></div>
                                                        </div>
                                                        <div class="chart-card">
                                                            <h4 class="chart-title">Events Per Month</h4>
                                                            <div class="chart-container-sm"><canvas
                                                                    id="monthlyChart"></canvas></div>
                                                        </div>
                                                        <div class="chart-card">
                                                            <h4 class="chart-title">Registration Trend</h4>
                                                            <div class="chart-container-sm"><canvas
                                                                    id="regChart"></canvas>
                                                            </div>
                                                        </div>
                                                        <div class="chart-card">
                                                            <h4 class="chart-title">Attendance Rate</h4>
                                                            <div class="attendance-rate-display">
                                                                <% const totalCap=(recentEvents || []).reduce((s,e)=> s
                                                                    +
                                                                    (e.capacity || 0), 0);
                                                                    const totalAtt = (recentEvents || []).reduce((s,e)
                                                                    => s
                                                                    + (e.attendees ? e.attendees.length : 0), 0);
                                                                    const attRate = totalCap > 0 ? Math.round((totalAtt
                                                                    /
                                                                    totalCap) * 100) : 0;
                                                                    %>
                                                                    <div class="rate-circle"
                                                                        style="background: conic-gradient(#667eea <%= attRate * 3.6 %>deg, #e2e8f0 0deg)">
                                                                        <span class="rate-value">
                                                                            <%= attRate %>%
                                                                        </span>
                                                                    </div>
                                                                    <p class="rate-label">
                                                                        <%= totalAtt %> registered / <%= totalCap %>
                                                                                capacity
                                                                    </p>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>

                                                <!-- Quick Actions -->
                                                <div class="dashboard-section">
                                                    <h2 class="section-title">Quick Actions</h2>
                                                    <div class="action-cards">
                                                        <a href="/club/create-event" class="action-card">
                                                            <div class="action-icon">
                                                                <i class="fas fa-plus-circle"></i>
                                                            </div>
                                                            <div class="action-content">
                                                                <h3>Create Event</h3>
                                                                <p>Plan and submit a new hackathon event</p>
                                                            </div>
                                                        </a>

                                                        <a href="/club/events" class="action-card">
                                                            <div class="action-icon">
                                                                <i class="fas fa-list"></i>
                                                            </div>
                                                            <div class="action-content">
                                                                <h3>My Events</h3>
                                                                <p>View and manage your events</p>
                                                            </div>
                                                        </a>

                                                        <a href="/club/events?history=true" class="action-card">
                                                            <div class="action-icon">
                                                                <i class="fas fa-history"></i>
                                                            </div>
                                                            <div class="action-content">
                                                                <h3>Event History</h3>
                                                                <p>View past events and analytics</p>
                                                            </div>
                                                        </a>
                                                    </div>
                                                </div>

                                                <!-- Recent Events -->
                                                <div class="dashboard-section">
                                                    <div class="section-header">
                                                        <h2 class="section-title">Recent Events</h2>
                                                        <a href="/club/events" class="section-link">View All</a>
                                                    </div>

                                                    <% if (recentEvents && recentEvents.length> 0) { %>
                                                        <div class="events-grid">
                                                            <% recentEvents.forEach(event=> { %>
                                                                <div class="event-card">
                                                                    <div class="event-header">
                                                                        <div class="event-title">
                                                                            <h3>
                                                                                <%= event.name %>
                                                                            </h3>
                                                                            <span
                                                                                class="event-status status-<%= event.status %>">
                                                                                <%= event.status.charAt(0).toUpperCase()
                                                                                    + event.status.slice(1) %>
                                                                            </span>
                                                                        </div>
                                                                    </div>

                                                                    <div class="event-details">
                                                                        <div class="event-info">
                                                                            <i class="fas fa-calendar"></i>
                                                                            <span>
                                                                                <%= new
                                                                                    Date(event.date).toLocaleDateString()
                                                                                    %>
                                                                            </span>
                                                                        </div>

                                                                        <div class="event-info">
                                                                            <i class="fas fa-map-marker-alt"></i>
                                                                            <span>
                                                                                <%= event.venue ? event.venue.name
                                                                                    : 'TBA' %>
                                                                            </span>
                                                                        </div>

                                                                        <div class="event-info">
                                                                            <i class="fas fa-users"></i>
                                                                            <span>
                                                                                <%= event.attendees ?
                                                                                    event.attendees.length : 0 %>
                                                                                    registered
                                                                            </span>
                                                                        </div>
                                                                    </div>

                                                                    <div class="event-actions">

                                                                        <% if (event.status==='approved' ) { %>

                                                                            <a href="/student/events/<%= event._id %>"
                                                                                class="btn btn-sm btn-outline">
                                                                                <i class="fas fa-eye"></i>
                                                                                View
                                                                            </a>

                                                                            <a href="/chat/event/<%= event._id %>"
                                                                                class="btn btn-sm btn-primary">
                                                                                <i class="fas fa-comments"></i>
                                                                                Chat
                                                                            </a>

                                                                            <% } else if (event.status==='pending' ) {
                                                                                %>

                                                                                <span class="status-text">
                                                                                    <i class="fas fa-clock"></i>
                                                                                    Awaiting Approval
                                                                                </span>

                                                                                <% } else if (event.status==='rejected'
                                                                                    ) { %>

                                                                                    <span class="status-text error">
                                                                                        <i
                                                                                            class="fas fa-times-circle"></i>
                                                                                        Rejected
                                                                                    </span>

                                                                                    <% } else if
                                                                                        (event.status==='completed' ) {
                                                                                        %>

                                                                                        <span
                                                                                            class="status-text success">
                                                                                            <i
                                                                                                class="fas fa-check-circle"></i>
                                                                                            Completed
                                                                                        </span>

                                                                                        <% } %>

                                                                    </div>
                                                                </div>
                                                                <% }) %>
                                                        </div>

                                                        <% } else { %>

                                                            <div class="empty-state">
                                                                <i class="fas fa-calendar-plus"></i>
                                                                <h3>No Events Yet</h3>
                                                                <p>Start by creating your first hackathon event!</p>
                                                                <a href="/club/create-event" class="btn btn-primary">
                                                                    <i class="fas fa-plus"></i>
                                                                    Create Your First Event
                                                                </a>
                                                            </div>

                                                            <% } %>
                                                </div>

                                                <!-- Club Information -->
                                                <% if (clubs && clubs.length> 0) {
                                                    const club = clubs[0];
                                                    %>
                                                    <div class="dashboard-section">
                                                        <h2 class="section-title">Club Information</h2>

                                                        <div class="clubs-grid">
                                                            <div class="club-card">
                                                                <div class="club-header">
                                                                    <h3>
                                                                        <%= club.name %>
                                                                    </h3>
                                                                    <span class="club-status active">
                                                                        <i class="fas fa-check-circle"></i>
                                                                        Active
                                                                    </span>
                                                                </div>

                                                                <p class="club-description">
                                                                    <%= club.description || 'No description available.'
                                                                        %>
                                                                </p>

                                                                <div class="club-stats">
                                                                    <div class="club-stat">
                                                                        <span class="stat-value">
                                                                            <%= totalEvents || 0 %>
                                                                        </span>
                                                                        <span class="stat-label">Events</span>
                                                                    </div>

                                                                    <div class="club-stat">
                                                                        <span class="stat-value">
                                                                            <%= club.members ? club.members.length : 0
                                                                                %>
                                                                        </span>
                                                                        <span class="stat-label">Members</span>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <% } %>

                                                        <!-- Activity Feed -->
                                                        <div class="dashboard-section">
                                                            <%- include('../partials/activity-feed', { activities:
                                                                activities || [], feedTitle: 'Club Activity' ,
                                                                showViewAll: true }) %>
                                                        </div>
                </main>

                <% if (locals.showNavbar !==false) { %>
                    <%- include('../partials/footer') %>
                        <% } %>

                            <!-- Toast Notifications -->
                            <div id="toast-container" class="toast-container"></div>

                            <script src="/js/main.js"></script>
                            <script src="/js/components.js"></script>
                            <script src="/js/notifications.js"></script>

                            <script>
                                // Auto-hide alerts after 5 seconds
                                document.addEventListener('DOMContentLoaded', function () {
                                    const alerts = document.querySelectorAll('.alert');
                                    alerts.forEach(alert => {
                                        setTimeout(() => {
                                            alert.style.opacity = '0';
                                            setTimeout(() => alert.remove(), 300);
                                        }, 5000);
                                    });
                                });
                            </script>

                            <script>
                                document.addEventListener('DOMContentLoaded', function () {
                                    // === Status Distribution Doughnut ===
                                    const approved = <%= activeEvents || 0 %>;
                                    const pending = <%= pendingEvents || 0 %>;
                                    const total = <%= totalEvents || 0 %>;
                                    const completed = Math.max(0, total - approved - pending);
                                    new Chart(document.getElementById('statusChart'), {
                                        type: 'doughnut',
                                        data: {
                                            labels: ['Approved', 'Pending', 'Completed'],
                                            datasets: [{
                                                data: [approved, pending, completed],
                                                backgroundColor: ['#48bb78', '#ecc94b', '#667eea'],
                                                borderWidth: 0
                                            }]
                                        },
                                        options: {
                                            responsive: true, maintainAspectRatio: false,
                                            plugins: { legend: { position: 'bottom', labels: { padding: 12, usePointStyle: true } } }
                                        }
                                    });

                                    // === Events Per Month Bar ===
                                    const evts = <% - JSON.stringify((recentEvents || []).map(e => ({ d: e.date }))) %>;
                                    const monthCounts = {};
                                    const monthNames = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
                                    evts.forEach(e => {
                                        const d = new Date(e.d);
                                        const key = monthNames[d.getMonth()] + ' ' + d.getFullYear();
                                        monthCounts[key] = (monthCounts[key] || 0) + 1;
                                    });
                                    const mLabels = Object.keys(monthCounts).slice(-6);
                                    const mData = mLabels.map(k => monthCounts[k]);
                                    new Chart(document.getElementById('monthlyChart'), {
                                        type: 'bar',
                                        data: {
                                            labels: mLabels.length ? mLabels : ['No Data'],
                                            datasets: [{
                                                label: 'Events', data: mData.length ? mData : [0],
                                                backgroundColor: 'rgba(102,126,234,0.7)', borderRadius: 6, barThickness: 32
                                            }]
                                        },
                                        options: {
                                            responsive: true, maintainAspectRatio: false,
                                            scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } },
                                            plugins: { legend: { display: false } }
                                        }
                                    });

                                    // === Registration Trend Line ===
                                    const regEvts = <% - JSON.stringify((recentEvents || []).map(e => ({ d: e.date, r: e.attendees ? e.attendees.length : 0 }))) %>;
                                    regEvts.sort((a, b) => new Date(a.d) - new Date(b.d));
                                    const rLabels = regEvts.map(e => new Date(e.d).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }));
                                    const rData = regEvts.map(e => e.r);
                                    new Chart(document.getElementById('regChart'), {
                                        type: 'line',
                                        data: {
                                            labels: rLabels.length ? rLabels : ['No Data'],
                                            datasets: [{
                                                label: 'Registrations', data: rData.length ? rData : [0],
                                                borderColor: '#667eea', backgroundColor: 'rgba(102,126,234,0.1)',
                                                fill: true, tension: 0.4, pointBackgroundColor: '#667eea', pointRadius: 4
                                            }]
                                        },
                                        options: {
                                            responsive: true, maintainAspectRatio: false,
                                            scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } },
                                            plugins: { legend: { display: false } }
                                        }
                                    });
                                });
                            </script>

                            <style>
                                .charts-grid {
                                    display: grid;
                                    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
                                    gap: 1.5rem;
                                    margin-bottom: 1rem;
                                }

                                .chart-card {
                                    background: #fff;
                                    border-radius: 12px;
                                    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
                                    padding: 1.25rem;
                                }

                                .chart-title {
                                    margin: 0 0 0.75rem 0;
                                    font-size: 0.95rem;
                                    font-weight: 600;
                                    color: #4a5568;
                                }

                                .chart-container-sm {
                                    position: relative;
                                    height: 220px;
                                }

                                .attendance-rate-display {
                                    text-align: center;
                                    padding: 1.5rem 0;
                                }

                                .rate-circle {
                                    width: 120px;
                                    height: 120px;
                                    border-radius: 50%;
                                    margin: 0 auto 0.75rem;
                                    display: flex;
                                    align-items: center;
                                    justify-content: center;
                                }

                                .rate-value {
                                    font-size: 1.75rem;
                                    font-weight: 700;
                                    color: #2d3748;
                                    background: #fff;
                                    width: 90px;
                                    height: 90px;
                                    border-radius: 50%;
                                    display: flex;
                                    align-items: center;
                                    justify-content: center;
                                }

                                .rate-label {
                                    font-size: 0.8rem;
                                    color: #718096;
                                    margin: 0;
                                }

                                .page-header {
                                    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
                                    color: white;
                                    padding: 2rem 0;
                                    margin-bottom: 2rem;
                                }

                                .header-content {
                                    display: flex;
                                    justify-content: space-between;
                                    align-items: center;
                                    flex-wrap: wrap;
                                    gap: 1rem;
                                }

                                .page-title {
                                    font-size: 2rem;
                                    font-weight: 700;
                                    margin: 0;
                                    display: flex;
                                    align-items: center;
                                    gap: 0.5rem;
                                }

                                .page-subtitle {
                                    margin: 0.5rem 0 0 0;
                                    opacity: 0.9;
                                }

                                .stats-grid {
                                    display: grid;
                                    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
                                    gap: 1.5rem;
                                    margin-bottom: 2rem;
                                }

                                .stat-card {
                                    background: white;
                                    padding: 1.5rem;
                                    border-radius: 12px;
                                    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
                                    display: flex;
                                    align-items: center;
                                    gap: 1rem;
                                }

                                .stat-icon {
                                    width: 60px;
                                    height: 60px;
                                    background: linear-gradient(135deg, #667eea, #764ba2);
                                    border-radius: 12px;
                                    display: flex;
                                    align-items: center;
                                    justify-content: center;
                                    color: white;
                                    font-size: 1.5rem;
                                }

                                .stat-number {
                                    font-size: 2rem;
                                    font-weight: 700;
                                    color: #2d3748;
                                }

                                .stat-label {
                                    color: #718096;
                                    font-size: 0.9rem;
                                }

                                .dashboard-section {
                                    margin-bottom: 2rem;
                                }

                                .section-header {
                                    display: flex;
                                    justify-content: space-between;
                                    align-items: center;
                                    margin-bottom: 1rem;
                                }

                                .section-title {
                                    font-size: 1.5rem;
                                    font-weight: 600;
                                    color: #2d3748;
                                    margin: 0;
                                }

                                .section-link {
                                    color: #667eea;
                                    text-decoration: none;
                                    font-weight: 500;
                                }

                                .action-cards {
                                    display: grid;
                                    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
                                    gap: 1.5rem;
                                }

                                .action-card {
                                    background: white;
                                    padding: 1.5rem;
                                    border-radius: 12px;
                                    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
                                    text-decoration: none;
                                    color: inherit;
                                    display: flex;
                                    align-items: center;
                                    gap: 1rem;
                                    transition: transform 0.3s ease, box-shadow 0.3s ease;
                                }

                                .action-card:hover {
